{
    "chat.agent.maxRequests": 45,
    
    // Enable custom instruction files for GitHub Copilot
    "github.copilot.chat.codeGeneration.useInstructionFiles": true,
    
    // Enable AGENTS.md file support
    "chat.useAgentsMdFile": true,
    
    // Enable nested AGENTS.md files (experimental)
    "chat.useNestedAgentsMdFiles": true,
    
    // Custom instructions file locations
    "chat.instructionsFilesLocations": [
        ".github/instructions"
    ],
    
    // YAML schema validation - suppress false positives in GitHub Actions workflows
    // The CODECOV_TOKEN context access and github-pages environment warnings
    // work correctly at runtime in GitHub Actions
    "yaml.schemas": {
        "https://json.schemastore.org/github-workflow.json": ".github/workflows/*.yml"
    },
    "yaml.validate": true,
    "yaml.schemaStore.enable": true,
    "chat.tools.terminal.autoApprove": {
        "Move-Item": true,
        "Out-File": true,
        "dotnet build": true,
        "dotnet test": true,
        "Set-Content": true,
        "git add": true,
        "git commit": true,
        "git push": true,
        ".\\scripts\\build-documentation.ps1": true,
        "dotnet tool": true,
        "docfx": true,
        "start": true,
        "Copy-Item": true,
        "Test-Path": true,
        "New-Item": true,
        "gh": true,
        "dotnet pack": true,
        "git check-ignore": true,
        "git tag": true,
        "/^dotnet run --project samples/AgentEval\\.NuGetConsumer$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "dotnet run": true,
        "2..18": true,
        "1..18": true,
        "ForEach-Object": true,
        "git -C \"c:\\git\\joslat\\AgentEval\"": true,
        "nslookup": true
    }
}