{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": ["**/*.csproj"]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["**/*.md", "**/*.yml"],
        "exclude": ["_site/**", "templates/**"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern", "templates/modern"],
    "globalMetadata": {
      "_appTitle": "AgentEval",
      "_appName": "AgentEval",
      "_appFooter": "<span>AgentEval &copy; 2025-2026 | The .NET Evaluation Toolkit for AI Agents</span>",
      "_appLogoPath": "images/logo.png",
      "_appFaviconPath": "images/favicon.png",
      "_enableSearch": true,
      "_enableNewTab": true,
      "_disableContribution": false,
      "_disableToc": false,
      "_disableBreadcrumb": false,
      "_disableAffix": false,
      "_disableSideFilter": false,
      "_gitContribute": {
        "repo": "https://github.com/joslat/AgentEval",
        "branch": "main"
      }
    },
    "postProcessors": ["ExtractSearchIndex"]
  }
}
